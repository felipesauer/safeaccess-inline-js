{
    "testRunner": "vitest",
    "mutate": [
        "src/**/*.ts",
        "!src/**/*.test.ts",
        "!src/index.ts",
        "!src/contracts/**/*.ts",
        "!src/exceptions/**/*.ts",
        "!src/security/forbidden-keys.ts"
    ],
    "thresholds": {
        "high": 100,
        "low": 90,
        "break": 93
    },
    "timeoutMS": 30000,
    "coverageAnalysis": "perTest",
    "reporters": ["json", "clear-text", "progress", "dashboard"],
    "dashboard": {
        "project": "github.com/felipesauer/safeaccess-inline",
        "version": "main"
    },
    "jsonReporter": {
        "fileName": "reports/mutation/mutation.json"
    }
}
